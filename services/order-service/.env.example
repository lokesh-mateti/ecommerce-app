# Application
APP_NAME=order-service
APP_PORT=8000
LOG_LEVEL=info

# Inter-service communication — in EKS this is the Kubernetes Service DNS name
PRODUCT_SERVICE_URL=http://product-service.default.svc.cluster.local:8000

# Database (placeholder for future real DB integration)
DATABASE_URL=postgresql://user:password@localhost:5432/orders_db

# AWS (used in EKS via IRSA, not actual keys in real deployment)
AWS_REGION=us-east-1
