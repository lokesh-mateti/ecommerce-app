# Application
APP_NAME=api-gateway
APP_PORT=8000
LOG_LEVEL=info

# JWT auth — in production this comes from a Kubernetes Secret, never committed
JWT_SECRET_KEY=change-this-in-production

# Downstream microservices — Kubernetes Service DNS names in EKS
PRODUCT_SERVICE_URL=http://product-service.default.svc.cluster.local:8000
ORDER_SERVICE_URL=http://order-service.default.svc.cluster.local:8000

# AWS (used in EKS via IRSA, not actual keys in real deployment)
AWS_REGION=us-east-1
