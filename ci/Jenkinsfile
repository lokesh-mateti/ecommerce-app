pipeline {
    agent any

    parameters {
        choice(name: 'SERVICE', choices: ['auto-detect', 'product-service', 'order-service', 'api-gateway', 'ai-analyzer'], description: 'Which microservice to build (auto-detect checks git changes)')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Target environment')
        string(name: 'GITOPS_REPO', defaultValue: 'https://github.com/lokesh-mateti/ecommerce-gitops.git', description: 'GitOps repository URL')
    }

    environment {
        AWS_REGION       = 'us-east-1'
        AWS_ACCOUNT_ID   = credentials('aws-account-id')
        ECR_REGISTRY     = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        GITOPS_CREDS     = credentials('gitops-repo-creds')
        AI_ANALYZER_URL  = 'http://ai-analyzer.ecommerce-dev.svc.cluster.local/analyze/jenkins'
        AI_ANALYZER_URL = credentials('ai-analyzer-url')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect Changed Services') {
            steps {
                script {
                    if (params.SERVICE == 'auto-detect') {
                        def changes = sh(script: "git diff --name-only HEAD~1 HEAD || echo 'services/'", returnStdout: true).trim()
                        echo "Changed files:\n${changes}"

                        def services = []
                        if (changes.contains('services/product-service')) services.add('product-service')
                        if (changes.contains('services/order-service')) services.add('order-service')
                        if (changes.contains('services/api-gateway')) services.add('api-gateway')
                        if (changes.contains('services/ai-analyzer')) services.add('ai-analyzer')

                        if (services.isEmpty()) {
                            echo "No service changes detected. Skipping build."
                            currentBuild.result = 'NOT_BUILT'
                            error("No service changes detected in this commit.")
                        }

                        env.CHANGED_SERVICES = services.join(',')
                        echo "Services to build: ${env.CHANGED_SERVICES}"
                    } else {
                        env.CHANGED_SERVICES = params.SERVICE
                        echo "Manually selected service: ${env.CHANGED_SERVICES}"
                    }
                }
            }
        }

        stage('Build Services') {
            steps {
                script {
                    def servicesToBuild = env.CHANGED_SERVICES.split(',')

                    for (svc in servicesToBuild) {
                        def service = svc.trim()
                        def serviceDir = "services/${service}"
                        def imageTag = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"

                        echo "========== Building ${service} =========="

                        stage("${service} - Install Dependencies") {
                            dir(serviceDir) {
                                sh """
                                    python3 -m venv venv
                                    . venv/bin/activate
                                    pip install --upgrade pip
                                    pip install -r requirements.txt
                                """
                            }
                        }

                        stage("${service} - Unit Tests") {
                            dir(serviceDir) {
                                sh """
                                    . venv/bin/activate
                                    pytest tests/ -v --junitxml=test-results.xml
                                """
                            }
                        }

                        stage("${service} - SAST (Bandit)") {
                            dir(serviceDir) {
                                sh """
                                    . venv/bin/activate
                                    pip install bandit
                                    bandit -r app/ -f json -o bandit-report.json || true
                                """
                            }
                            archiveArtifacts artifacts: "${serviceDir}/bandit-report.json", allowEmptyArchive: true
                        }

                        stage("${service} - SCA (Safety)") {
                            dir(serviceDir) {
                                sh """
                                    . venv/bin/activate
                                    pip install safety
                                    safety check -r requirements.txt --json > safety-report.json || true
                                """
                            }
                            archiveArtifacts artifacts: "${serviceDir}/safety-report.json", allowEmptyArchive: true
                        }

                        stage("${service} - Build Docker Image") {
                            dir(serviceDir) {
                                sh """
                                    docker build -t ${service}:${imageTag} .
                                    docker tag ${service}:${imageTag} ${ECR_REGISTRY}/${service}:${imageTag}
                                """
                            }
                        }

                        stage("${service} - Trivy Scan") {
                            sh """
                                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                                    --format json --output trivy-report-${service}.json \
                                    ${service}:${imageTag} || true
                            """
                            archiveArtifacts artifacts: "trivy-report-${service}.json", allowEmptyArchive: true
                        }

                        stage("${service} - Push to ECR") {
                            sh """
                                aws ecr get-login-password --region ${AWS_REGION} | \
                                    docker login --username AWS --password-stdin ${ECR_REGISTRY}
                                docker push ${ECR_REGISTRY}/${service}:${imageTag}
                            """
                        }

                        stage("${service} - Update GitOps Repo") {
                            sh """
                                rm -rf gitops-repo
                                git clone https://${GITOPS_CREDS_USR}:${GITOPS_CREDS_PSW}@\$(echo ${params.GITOPS_REPO} | sed 's#https://##') gitops-repo
                                cd gitops-repo

                                sed -i "s|tag:.*|tag: ${imageTag}|g" apps/${service}/values-${params.ENVIRONMENT}.yaml

                                git config user.email "jenkins-ci@example.com"
                                git config user.name "Jenkins CI"
                                git add apps/${service}/values-${params.ENVIRONMENT}.yaml
                                git commit -m "ci: update ${service} image to ${imageTag} [${params.ENVIRONMENT}]"
                                git push origin main
                            """
                        }

                        stage("${service} - Cleanup") {
                            sh """
                                docker rmi ${service}:${imageTag} || true
                                docker rmi ${ECR_REGISTRY}/${service}:${imageTag} || true
                            """
                        }

                        echo "========== ${service} build complete =========="
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded for ${env.CHANGED_SERVICES} → ${params.ENVIRONMENT}. ArgoCD will auto-sync the new image."
        }
        failure {
            script {
                echo "Pipeline failed. Sending logs to AI Analyzer..."
                try {
                    def buildLog = sh(
                        script: "tail -100 ${env.JENKINS_HOME}/jobs/${env.JOB_NAME}/builds/${env.BUILD_NUMBER}/log 2>/dev/null || echo 'Build failed'",
                        returnStdout: true
                    ).trim()

                    writeFile file: 'ai-payload.json', text: groovy.json.JsonOutput.toJson([
                        log: buildLog,
                        service: env.CHANGED_SERVICES ?: 'unknown',
                        build_number: env.BUILD_NUMBER,
                        context: 'Jenkins CI/CD pipeline failure'
                    ])

                    def response = sh(
                        script: """
                            curl -s -X POST ${AI_ANALYZER_URL} \
                                -H 'Content-Type: application/json' \
                                -d @ai-payload.json \
                                --connect-timeout 10 \
                                --max-time 30 || echo '{"error": "AI analyzer unreachable"}'
                        """,
                        returnStdout: true
                    ).trim()

                    echo "============================================"
                    echo "AI FAILURE ANALYSIS"
                    echo "============================================"
                    echo "${response}"
                    echo "============================================"

                } catch (Exception e) {
                    echo "AI Analyzer call failed: ${e.message}"
                }
            }
        }
        always {
            cleanWs()
        }
    }
}
